# Copy this file to ".env" and fill in your real values. ".env" is gitignored.

# PostgreSQL connection string from Supabase / Neon.
# Supabase: Project Settings → Database → Connection string (URI). Use the
# "Connection pooling" / Transaction string for serverless, or the direct one for a
# long-running server. Make sure it ends with ?sslmode=require (or rely on SSL below).
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Port for the local Express server (optional, defaults to 4000).
PORT=4000
